{
  "manifest_version": 3,
  "name": "Booking Extractor",
  "version": "1.0",
  "description": "extractor for booking.com",
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html"
  }
}
